generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ClinicalTrial {
  id                 String    @id @default(cuid())
  source             String
  sourceId           String    @unique
  title              String
  titleCn            String?
  diseaseSlugs       String[]
  diseaseLabel       String
  phase              String
  status             String
  locations          String[]
  eligibility        String    @default("")
  summary            String    @default("")
  intervention       String    @default("")
  sponsor            String    @default("")
  contactInfo        String    @default("")
  isFree             Boolean   @default(true)
  freeLabel          String?
  crawledAt          DateTime
  recruitmentEndDate DateTime?
  startDate          DateTime?
  syncedAt           DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  @@index([status])
  @@index([crawledAt(sort: Desc)])
}

model Report {
  id                    String    @id @default(cuid())
  userId                String?
  sessionId             String
  status                String
  navigationDiseaseSlug String?
  conditionSummary      String?
  documentedDiagnosis   String?
  reviewedAt            DateTime?
  sentToUserAt          DateTime?
  createdAt             DateTime  @default(now())
}
